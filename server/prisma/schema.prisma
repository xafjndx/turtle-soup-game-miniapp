generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String        @id @default(uuid())
  openId          String?       @unique
  username        String        @unique
  nickname        String?
  avatarUrl       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  totalGames      Int           @default(0)
  winCount        Int           @default(0)
  hitRate         Float         @default(0)
  totalPlayTime   Float         @default(0)
  avgPlayTime     Float         @default(0)
  maxPlayTime     Float         @default(0)
  totalHintsUsed  Int           @default(0)
  avgHintsPerGame Float         @default(0)
  lastPlayedAt    DateTime?
  admin           Admin?
  gameHistories   GameHistory[]
  gameSessions    GameSession[]

  @@index([hitRate, totalGames, avgPlayTime])
  @@map("users")
}

model Admin {
  id          String   @id @default(uuid())
  userId      String   @unique
  role        String   @default("SUPER")
  permissions String   @default("[\"ALL\"]")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

model Question {
  id            String        @id @default(uuid())
  title         String?
  surface       String
  bottom        String
  category      String        @default("CLASSIC")
  hints         String
  keywords      String
  source        String        @default("PLATFORM")
  aiGeneratedBy String?
  aiGeneratedAt DateTime?
  crawlSource   String?
  crawlUrl      String?
  crawledAt     DateTime?
  addedAt       DateTime?
  status        String        @default("APPROVED")
  softDeletedAt DateTime?
  quality       Int           @default(3)
  playCount     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  gameHistories GameHistory[]
  gameSessions  GameSession[]

  @@index([category, status])
  @@index([source, status])
  @@map("questions")
}

model GameHistory {
  id             String   @id @default(uuid())
  userId         String
  questionId     String
  playedAt       DateTime @default(now())
  result         String
  hitRate        Float    @default(0)
  playTime       Float    @default(0)
  hintUsed       Int      @default(0)
  revealedAnswer Boolean  @default(false)
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, playedAt])
  @@map("game_histories")
}

model GameSession {
  id             String    @id @default(uuid())
  userId         String
  questionId     String
  questionSource String    @default("BANK")
  status         String    @default("ONGOING")
  hintUsed       Int       @default(0)
  hintRemaining  Int       @default(3)
  inputMode      String?
  result         String?
  hitRate        Float?
  revealedAnswer Boolean   @default(false)
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  totalTime      Float?
  question       Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  rounds         Round[]

  @@index([userId, status])
  @@map("game_sessions")
}

model Round {
  id            String      @id @default(uuid())
  sessionId     String
  roundNumber   Int
  inputMode     String
  playerInput   String
  inputAudioUrl String?
  answerType    String?
  aiResponse    String?
  action        String
  createdAt     DateTime    @default(now())
  session       GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, roundNumber])
  @@map("rounds")
}

model PromptLibrary {
  id          String   @id @default(uuid())
  category    String
  prompt      String
  usageCount  Int      @default(0)
  generatedBy String   @default("AI_AUTO")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@map("prompt_library")
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

model OperationLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  target    String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([adminId, createdAt])
  @@map("operation_logs")
}
