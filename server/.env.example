# ==================== 服务器配置 ====================
PORT=3000
NODE_ENV=development

# ==================== 数据库配置 ====================
# 开发环境使用 SQLite
DATABASE_URL="file:./dev.db"

# 生产环境使用 MySQL（微信云托管）
# DATABASE_URL="mysql://用户名:密码@数据库地址:3306/数据库名"

# ==================== 安全配置 ====================
# JWT 密钥（生产环境请使用强密钥）
JWT_SECRET=请替换为安全的随机字符串

# ==================== 微信小程序配置 ====================
# 从微信公众平台获取
WECHAT_APPID=你的小程序AppID
WECHAT_SECRET=你的小程序AppSecret

# ==================== AI 服务配置 ====================
# 阿里百炼 API（用于 AI 判定和题目生成）
ALIBABA_DASHSCOPE_API_KEY=你的阿里云API密钥
QWEN_MODEL=qwen3.5-plus

# ==================== 管理员配置 ====================
# 管理后台登录密码（生产环境请设置强密码）
ADMIN_PASSWORD=请设置管理员密码

# ==================== 爬虫配置（已禁用）====================
# 爬虫功能已禁用，以下配置无效
CRAWLER_ENABLED=false
CRAWLER_CRON=""

# ==================== 日志配置 ====================
LOG_LEVEL=info

# ==================== 安全提醒 ====================
# 1. 生产环境必须使用 HTTPS
# 2. JWT_SECRET 必须使用强随机字符串
# 3. 请勿将此文件提交到代码仓库
# 4. 生产环境请使用环境变量或密钥管理服务