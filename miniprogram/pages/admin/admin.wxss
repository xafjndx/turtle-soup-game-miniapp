/* pages/admin/admin.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 登录区域 */
.login-section {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
}

.login-card {
  width: 90%;
  max-width: 500rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 50rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.login-title {
  display: block;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.password-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.login-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 12rpx;
  border: none;
}

.login-btn::after {
  border: none;
}

.login-tip {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #ff4d4f;
  margin-top: 16rpx;
}

/* Tab 切换 */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 16rpx;
  gap: 12rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.tab-item.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

/* Tab 内容 */
.tab-content {
  padding: 16rpx;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.stat-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
}

.stat-card.highlight {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.stat-card.highlight .stat-value,
.stat-card.highlight .stat-label {
  color: #fff;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 分类统计 */
.category-stats {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
  padding-bottom: 8rpx;
}

.category-card {
  flex-shrink: 0;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  text-align: center;
  border: 2rpx solid transparent;
}

.category-card.active {
  border-color: #667eea;
  background: #f0e8ff;
}

.category-name {
  display: block;
  font-size: 24rpx;
  color: #333;
}

.category-count {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
  margin-top: 4rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.search-input {
  flex: 1;
  height: 64rpx;
  background: #fff;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
}

.btn-add {
  height: 64rpx;
  padding: 0 24rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 24rpx;
  border-radius: 10rpx;
  border: none;
  line-height: 64rpx;
}

.btn-add::after {
  border: none;
}

/* 表格样式 */
.table-container {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.table-header {
  display: flex;
  background: #f5f5f5;
  padding: 16rpx 12rpx;
  border-bottom: 1rpx solid #eee;
}

.table-body {
  max-height: 600rpx;
  overflow-y: auto;
}

.table-row {
  display: flex;
  padding: 16rpx 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
  align-items: center;
}

.table-row:active {
  background: #f9f9f9;
}

.th, .td {
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.th-name, .td-name { width: 160rpx; flex-shrink: 0; }
.th-title, .td-title { width: 160rpx; flex-shrink: 0; }
.th-user, .td-user { width: 100rpx; flex-shrink: 0; }
.th-time, .td-time { width: 140rpx; flex-shrink: 0; }
.th-games, .td-games { width: 80rpx; flex-shrink: 0; text-align: center; }
.th-rate, .td-rate { width: 100rpx; flex-shrink: 0; text-align: center; }
.th-index, .td-index { width: 60rpx; flex-shrink: 0; text-align: center; font-weight: bold; }
.th-category, .td-category { width: 100rpx; flex-shrink: 0; }
.th-surface, .td-surface { flex: 1; min-width: 0; }
.th-status, .td-status { width: 80rpx; flex-shrink: 0; text-align: center; }
.th-action, .td-action { width: 140rpx; flex-shrink: 0; text-align: right; }

.td-status {
  font-size: 22rpx;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
}

.status-APPROVED { color: #4caf50; background: #e8f5e9; }
.status-PENDING { color: #ff9800; background: #fff8e1; }
.status-REJECTED { color: #f44336; background: #ffebee; }

.action-link {
  color: #667eea;
  font-size: 22rpx;
  margin-left: 12rpx;
}

.action-link.delete {
  color: #f44336;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.modal-content {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-title {
  font-size: 30rpx;
  font-weight: bold;
  text-align: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-body {
  padding: 24rpx;
  max-height: 50vh;
}

.modal-form {
  padding: 24rpx;
  max-height: 60vh;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx 24rpx;
  border-top: 1rpx solid #eee;
}

.pending-actions {
  justify-content: space-between;
}

.pending-actions button {
  flex: 1;
}

.detail-row {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-section {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-label {
  font-size: 26rpx;
  color: #999;
  width: 140rpx;
  flex-shrink: 0;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 100rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 20rpx;
  color: #999;
  margin-top: 6rpx;
}

.picker-value {
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  line-height: 64rpx;
  color: #333;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  display: block;
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

/* 按钮样式 */
.btn-cancel, .btn-save, .btn-edit, .btn-approve, .btn-reject, .btn-delete {
  height: 72rpx;
  font-size: 26rpx;
  border-radius: 10rpx;
  border: none;
  flex: 1;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-save {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

.btn-edit {
  background: #fff3e0;
  color: #ff9800;
}

.btn-delete {
  background: #ffebee;
  color: #f44336;
}

.btn-approve {
  background: #e8f5e9;
  color: #4caf50;
}

.btn-reject {
  background: #ffebee;
  color: #f44336;
}

.btn-cancel::after, .btn-save::after, .btn-edit::after, .btn-delete::after, .btn-approve::after, .btn-reject::after {
  border: none;
}

/* 待审核详情弹窗 */
.question-detail-modal {
  max-width: 650rpx;
}

.question-detail-modal .modal-body {
  padding: 24rpx 50rpx; /* 增加左右边距到 50rpx，避免文本贴边 */
}

.question-detail-modal .detail-row,
.question-detail-modal .detail-section {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.question-detail-modal .detail-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
  display: block;
  font-weight: 500;
}

.question-detail-modal .detail-value {
  font-size: 26rpx;
  color: #333;
  line-height: 1.8; /* 增加行高 */
  display: block;
  word-break: break-all; /* 防止长文本溢出 */
  white-space: normal; /* 允许换行 */
  padding-right: 8rpx; /* 右侧留白 */
}

.question-detail-modal .detail-section {
  border-bottom: 1rpx solid #f5f5f5;
  padding: 16rpx 0; /* 增加 section 的上下间距 */
}

.question-modal {
  max-width: 650rpx;
}

/* 编辑弹窗表单 - 增加左右边距，使输入框与边界对称 */
.modal-form {
  padding: 24rpx 50rpx; /* 左右边距从 30rpx 增加到 50rpx */
  max-height: 60vh;
}