<!--pages/admin/admin.wxml-->
<view class="container">
  <!-- 密码登录 -->
  <view class="login-section" wx:if="{{!isLoggedIn}}">
    <view class="login-card">
      <text class="login-title">🔐 管理员登录</text>
      <input 
        class="password-input"
        type="password"
        placeholder="请输入管理密码"
        password="{{true}}"
        value="{{password}}"
        bindinput="onInputPassword"
      />
      <button class="login-btn" bindtap="onLogin">登录</button>
      <text class="login-tip" wx:if="{{loginError}}">{{loginError}}</text>
    </view>
  </view>

  <!-- 管理界面 -->
  <block wx:else>
    <!-- Tab 切换 -->
    <view class="tab-bar">
      <view class="tab-item {{currentTab === 'overview' ? 'active' : ''}}" data-tab="overview" bindtap="switchTab">概览</view>
      <view class="tab-item {{currentTab === 'users' ? 'active' : ''}}" data-tab="users" bindtap="switchTab">用户</view>
      <view class="tab-item {{currentTab === 'questions' ? 'active' : ''}}" data-tab="questions" bindtap="switchTab">题库</view>
      <view class="tab-item {{currentTab === 'pending' ? 'active' : ''}}" data-tab="pending" bindtap="switchTab">审核</view>
    </view>

    <!-- 概览 -->
    <view class="tab-content" wx:if="{{currentTab === 'overview'}}">
      <view class="stats-grid">
        <view class="stat-card">
          <text class="stat-value">{{stats.users.total}}</text>
          <text class="stat-label">总用户</text>
        </view>
        <view class="stat-card">
          <text class="stat-value">{{stats.questions.total}}</text>
          <text class="stat-label">题目总数</text>
        </view>
        <view class="stat-card highlight">
          <text class="stat-value">{{stats.questions.pending}}</text>
          <text class="stat-label">待审核</text>
        </view>
        <view class="stat-card">
          <text class="stat-value">{{stats.games.total}}</text>
          <text class="stat-label">游戏总数</text>
        </view>
        <view class="stat-card">
          <text class="stat-value">{{stats.games.winRate}}</text>
          <text class="stat-label">胜率</text>
        </view>
        <view class="stat-card">
          <text class="stat-value">{{stats.games.today}}</text>
          <text class="stat-label">今日游戏</text>
        </view>
      </view>
    </view>

    <!-- 用户管理 -->
    <view class="tab-content" wx:if="{{currentTab === 'users'}}">
      <view class="search-bar">
        <input class="search-input" placeholder="搜索用户..." value="{{userSearch}}" bindinput="onSearchUser" />
      </view>
      <view class="table-container">
        <view class="table-header">
          <text class="th th-name">用户名</text>
          <text class="th th-games">游戏</text>
          <text class="th th-rate">命中率</text>
          <text class="th th-action">操作</text>
        </view>
        <view class="table-body">
          <view class="table-row" wx:for="{{filteredUsers}}" wx:key="id">
            <text class="td td-name">{{item.nickname || item.username}}</text>
            <text class="td td-games">{{item.totalGames}}</text>
            <text class="td td-rate">{{item.hitRate}}%</text>
            <view class="td td-action">
              <text class="action-link" data-id="{{item.id}}" bindtap="onViewUserDetail">详情</text>
              <text class="action-link delete" data-id="{{item.id}}" bindtap="onDeleteUser">删除</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 题库管理 -->
    <view class="tab-content" wx:if="{{currentTab === 'questions'}}">
      <!-- 分类统计 -->
      <view class="category-stats">
        <view class="category-card {{selectedCategory === '' ? 'active' : ''}}" bindtap="onSelectCategoryFilter" data-category="">
          <text class="category-name">全部</text>
          <text class="category-count">{{stats.questions.total}}</text>
        </view>
        <view class="category-card {{selectedCategory === 'CLASSIC' ? 'active' : ''}}" bindtap="onSelectCategoryFilter" data-category="CLASSIC">
          <text class="category-name">经典推理</text>
          <text class="category-count">{{categoryCounts.CLASSIC || 0}}</text>
        </view>
        <view class="category-card {{selectedCategory === 'HORROR' ? 'active' : ''}}" bindtap="onSelectCategoryFilter" data-category="HORROR">
          <text class="category-name">恐怖悬疑</text>
          <text class="category-count">{{categoryCounts.HORROR || 0}}</text>
        </view>
        <view class="category-card {{selectedCategory === 'LOGIC' ? 'active' : ''}}" bindtap="onSelectCategoryFilter" data-category="LOGIC">
          <text class="category-name">逻辑陷阱</text>
          <text class="category-count">{{categoryCounts.LOGIC || 0}}</text>
        </view>
        <view class="category-card {{selectedCategory === 'WARM' ? 'active' : ''}}" bindtap="onSelectCategoryFilter" data-category="WARM">
          <text class="category-name">温情反转</text>
          <text class="category-count">{{categoryCounts.WARM || 0}}</text>
        </view>
      </view>
      
      <view class="search-bar">
        <input class="search-input" placeholder="搜索题目..." value="{{questionSearch}}" bindinput="onSearchQuestion" />
        <button class="btn-add" bindtap="onAddQuestion">+ 新增</button>
      </view>
      
      <view class="table-container">
        <view class="table-header">
          <text class="th th-category">分类</text>
          <text class="th th-surface">汤面</text>
          <text class="th th-status">状态</text>
          <text class="th th-action">操作</text>
        </view>
        <view class="table-body">
          <view class="table-row" wx:for="{{filteredQuestions}}" wx:key="id">
            <text class="td td-category">{{item.categoryName}}</text>
            <text class="td td-surface">{{item.surfaceShort}}</text>
            <text class="td td-status status-{{item.status}}">{{item.statusName}}</text>
            <view class="td td-action">
              <text class="action-link" data-id="{{item.id}}" bindtap="onViewQuestion">详情</text>
              <text class="action-link" data-id="{{item.id}}" bindtap="onEditQuestion">编辑</text>
              <text class="action-link delete" data-id="{{item.id}}" bindtap="onDeleteQuestion">删除</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 待审核 -->
    <view class="tab-content" wx:if="{{currentTab === 'pending'}}">
      <view class="empty-tip" wx:if="{{pendingQuestions.length === 0}}">
        <text class="empty-icon">🎉</text>
        <text class="empty-text">暂无待审核题目</text>
      </view>
      <view class="table-container" wx:else>
        <view class="table-header">
          <text class="th th-title">标题</text>
          <text class="th th-user">投稿者</text>
          <text class="th th-time">时间</text>
          <text class="th th-action">操作</text>
        </view>
        <view class="table-body">
          <view class="table-row" wx:for="{{pendingQuestions}}" wx:key="id" data-id="{{item.id}}" bindtap="onViewPendingDetail">
            <text class="td td-title">{{item.title || '无标题'}}</text>
            <text class="td td-user">{{item.submitterName || '匿名'}}</text>
            <text class="td td-time">{{item.timeShort}}</text>
            <view class="td td-action" catchtap="stopPropagation">
              <text class="action-link" data-id="{{item.id}}" catchtap="onApproveQuestion">通过</text>
              <text class="action-link" data-id="{{item.id}}" catchtap="onEditPending">编辑</text>
              <text class="action-link delete" data-id="{{item.id}}" catchtap="onRejectQuestion">驳回</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>

<!-- 用户详情弹窗 -->
<view class="modal-mask" wx:if="{{showUserDetailModal}}" bindtap="closeUserDetailModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-title">用户详情</view>
    <view class="modal-body">
      <view class="detail-row">
        <text class="detail-label">用户名：</text>
        <text class="detail-value">{{userDetail.username}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">昵称：</text>
        <text class="detail-value">{{userDetail.nickname || '未设置'}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">游戏总数：</text>
        <text class="detail-value">{{userDetail.totalGames}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">胜场：</text>
        <text class="detail-value">{{userDetail.winCount}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">命中率：</text>
        <text class="detail-value">{{userDetail.hitRate}}%</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">注册时间：</text>
        <text class="detail-value">{{userDetail.createdAt}}</text>
      </view>
    </view>
    <view class="modal-actions">
      <button class="btn-cancel" bindtap="closeUserDetailModal">关闭</button>
    </view>
  </view>
</view>

<!-- 题目详情弹窗 -->
<view class="modal-mask" wx:if="{{showQuestionDetailModal}}" bindtap="closeQuestionDetailModal">
  <view class="modal-content question-detail-modal" catchtap="stopPropagation">
    <view class="modal-title">题目详情</view>
    <scroll-view scroll-y class="modal-body">
      <view class="detail-row">
        <text class="detail-label">分类：</text>
        <text class="detail-value">{{questionDetail.categoryName}}</text>
      </view>
      <view class="detail-section">
        <text class="detail-label">汤面：</text>
        <text class="detail-value">{{questionDetail.surface}}</text>
      </view>
      <view class="detail-section">
        <text class="detail-label">汤底：</text>
        <text class="detail-value">{{questionDetail.bottom}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">提示：</text>
        <text class="detail-value">{{questionDetail.hintsText}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">关键词：</text>
        <text class="detail-value">{{questionDetail.keywordsText}}</text>
      </view>
    </scroll-view>
    <view class="modal-actions">
      <button class="btn-cancel" bindtap="closeQuestionDetailModal">关闭</button>
      <button class="btn-edit" bindtap="editFromDetail">编辑</button>
    </view>
  </view>
</view>

<!-- 待审核详情弹窗 -->
<view class="modal-mask" wx:if="{{showPendingDetailModal}}" bindtap="closePendingDetailModal">
  <view class="modal-content question-detail-modal" catchtap="stopPropagation">
    <view class="modal-title">投稿详情</view>
    <scroll-view scroll-y class="modal-body">
      <view class="detail-row">
        <text class="detail-label">标题：</text>
        <text class="detail-value">{{pendingDetail.title || '无标题'}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">投稿者：</text>
        <text class="detail-value">{{pendingDetail.submitterName || '匿名'}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">分类：</text>
        <text class="detail-value">{{pendingDetail.categoryName}}</text>
      </view>
      <view class="detail-section">
        <text class="detail-label">汤面：</text>
        <text class="detail-value">{{pendingDetail.surface}}</text>
      </view>
      <view class="detail-section">
        <text class="detail-label">汤底：</text>
        <text class="detail-value">{{pendingDetail.bottom}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">提示：</text>
        <text class="detail-value">{{pendingDetail.hintsText}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">关键词：</text>
        <text class="detail-value">{{pendingDetail.keywordsText}}</text>
      </view>
    </scroll-view>
    <view class="modal-actions pending-actions">
      <button class="btn-reject" bindtap="rejectPending">驳回</button>
      <button class="btn-edit" bindtap="editPendingFromDetail">编辑</button>
      <button class="btn-approve" bindtap="approvePending">通过</button>
    </view>
  </view>
</view>

<!-- 编辑题目弹窗 -->
<view class="modal-mask" wx:if="{{showQuestionModal}}" bindtap="closeQuestionModal">
  <view class="modal-content question-modal" catchtap="stopPropagation">
    <view class="modal-title">{{editQuestion.id ? '编辑题目' : '新增题目'}}</view>
    <scroll-view scroll-y class="modal-form">
      <view class="form-item">
        <text class="form-label">标题 *</text>
        <input class="form-input" value="{{editQuestion.title}}" bindinput="onInputTitle" placeholder="给题目起个名字" maxlength="50" />
      </view>
      <view class="form-item">
        <text class="form-label">分类 *</text>
        <picker mode="selector" range="{{categories}}" range-key="label" value="{{categoryIndex}}" bindchange="onPickCategory">
          <view class="picker-value">{{categories[categoryIndex].label}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="form-label">汤面 *</text>
        <textarea class="form-textarea" value="{{editQuestion.surface}}" bindinput="onInputSurface" placeholder="50-100字，简洁有趣" maxlength="150" />
        <text class="char-count">{{editQuestion.surfaceLength}}/150</text>
      </view>
      <view class="form-item">
        <text class="form-label">汤底 *</text>
        <textarea class="form-textarea" value="{{editQuestion.bottom}}" bindinput="onInputBottom" placeholder="50字以内，逻辑严密" maxlength="100" />
        <text class="char-count">{{editQuestion.bottomLength}}/100</text>
      </view>
      <view class="form-item">
        <text class="form-label">提示1</text>
        <input class="form-input" value="{{editQuestion.hint1}}" bindinput="onInputHint1" placeholder="第一个提示（最简单）" maxlength="100" />
      </view>
      <view class="form-item">
        <text class="form-label">提示2</text>
        <input class="form-input" value="{{editQuestion.hint2}}" bindinput="onInputHint2" placeholder="第二个提示（中等难度）" maxlength="100" />
      </view>
      <view class="form-item">
        <text class="form-label">提示3</text>
        <input class="form-input" value="{{editQuestion.hint3}}" bindinput="onInputHint3" placeholder="第三个提示（最难）" maxlength="100" />
      </view>
      <view class="form-item">
        <text class="form-label">关键词（逗号分隔）</text>
        <input class="form-input" value="{{editQuestion.keywordsText}}" bindinput="onInputKeywords" placeholder="关键词1, 关键词2, 关键词3" />
      </view>
    </scroll-view>
    <view class="modal-actions">
      <button class="btn-cancel" bindtap="closeQuestionModal">取消</button>
      <button class="btn-delete" bindtap="onDeleteQuestion" wx:if="{{editQuestion.id}}">删除</button>
      <button class="btn-save" bindtap="onSaveQuestion">保存</button>
    </view>
  </view>
</view>