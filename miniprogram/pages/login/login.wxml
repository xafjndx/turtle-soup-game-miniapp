<!--pages/login/login.wxml-->
<view class="container">
  <!-- Logo 区域 -->
  <view class="logo-area">
    <view class="logo">🐢</view>
    <text class="title">海龟汤</text>
    <text class="subtitle">推理游戏</text>
  </view>

  <!-- 排行榜 TOP3 -->
  <view class="top3-section" wx:if="{{top3.length > 0}}">
    <view class="section-title">🏆 命中率排行榜</view>
    <view class="top3-list">
      <view class="top3-item" wx:for="{{top3}}" wx:key="id">
        <view class="rank">{{index + 1}}</view>
        <view class="info">
          <text class="name">{{item.nickname || item.username}}</text>
          <text class="hit-rate">命中率 {{item.hitRate}}%</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 登录区域 -->
  <view class="login-area">
    <!-- 新用户注册 -->
    <view class="register-section" wx:if="{{isNewUser}}">
      <input 
        class="username-input"
        type="text"
        placeholder="请输入用户名"
        maxlength="20"
        value="{{username}}"
        bindinput="onInputUsername"
      />
      <button class="btn-primary" bindtap="onUsernameLogin" loading="{{loading}}">
        开始游戏
      </button>
      <view class="switch-text" bindtap="toggleMode" wx:if="{{existingUsers.length > 0}}">
        已有账号？点击登录
      </view>
    </view>

    <!-- 已有账号选择 -->
    <view class="existing-section" wx:else>
      <view class="section-title">选择账号登录</view>
      <view class="user-list">
        <view 
          class="user-item" 
          wx:for="{{existingUsers}}" 
          wx:key="id"
          data-username="{{item.username}}"
          bindtap="onSelectUser"
        >
          <image class="avatar" src="{{item.avatarUrl || '/assets/images/default-avatar.png'}}" />
          <text class="username">{{item.nickname || item.username}}</text>
        </view>
      </view>
      <view class="switch-text" bindtap="toggleMode">
        创建新账号
      </view>
    </view>

    <!-- 微信登录 -->
    <view class="wechat-login">
      <view class="divider">
        <text>或</text>
      </view>
      <button class="btn-wechat" bindtap="onWechatLogin" loading="{{loading}}">
        <text class="icon">📱</text> 微信一键登录
      </button>
    </view>
  </view>

  <!-- 底部隐私政策入口 -->
  <view class="footer-privacy" bindtap="onViewPrivacy">
    <text>《隐私政策》</text>
  </view>
</view>

<!-- 隐私政策同意弹窗 -->
<view class="privacy-modal-mask" wx:if="{{showPrivacyModal}}" catchtouchmove="true">
  <view class="privacy-modal">
    <view class="privacy-modal-header">
      <text class="privacy-modal-title">🔐 用户协议与隐私政策</text>
    </view>
    <view class="privacy-modal-body">
      <view class="privacy-notice">
        <text class="notice-title">欢迎使用海龟汤游戏！</text>
        <text class="notice-text">在使用我们的服务前，请您仔细阅读并同意以下协议：</text>
      </view>
      <view class="privacy-list">
        <view class="privacy-item" bindtap="onViewPrivacy">
          <text class="privacy-icon">📄</text>
          <text class="privacy-name">《用户协议》</text>
          <text class="privacy-arrow">></text>
        </view>
        <view class="privacy-item" bindtap="onViewPrivacy">
          <text class="privacy-icon">🔒</text>
          <text class="privacy-name">《隐私政策》</text>
          <text class="privacy-arrow">></text>
        </view>
      </view>
      <view class="privacy-summary">
        <text>我们将严格保护您的个人信息安全，具体包括：</text>
        <text>• 微信登录仅用于身份识别</text>
        <text>• 游戏记录用于统计和排行榜</text>
        <text>• 语音数据仅用于即时识别，不存储</text>
      </view>
    </view>
    <view class="privacy-modal-footer">
      <button class="btn-reject" bindtap="onRejectPrivacy">不同意</button>
      <button class="btn-agree" bindtap="onAgreePrivacy">同意并继续</button>
    </view>
  </view>
</view>