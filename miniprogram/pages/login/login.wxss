/* pages/login/login.wxss */
.container {
  min-height: 100vh;
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 100rpx;
}

.logo-area {
  text-align: center;
  padding: 30rpx 0 20rpx;
}

.logo {
  font-size: 80rpx;
  margin-bottom: 10rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 6rpx;
}

.top3-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.top3-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.top3-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.top3-item .rank {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffd700, #ffaa00);
  color: #fff;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.top3-item .info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.top3-item .name {
  font-size: 24rpx;
  color: #333;
}

.top3-item .hit-rate {
  font-size: 20rpx;
  color: #667eea;
  font-weight: bold;
}

.login-area {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 24rpx;
}

.username-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.btn-primary {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 10rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}

.switch-text {
  text-align: center;
  font-size: 24rpx;
  color: #667eea;
  margin-top: 20rpx;
}

.user-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.user-item {
  width: calc((100% - 20rpx) / 3);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 6rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
}

.user-item .avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
}

.user-item .username {
  font-size: 20rpx;
  color: #333;
  text-align: center;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 底部隐私政策入口 */
.footer-privacy {
  position: fixed;
  bottom: 30rpx;
  left: 0;
  right: 0;
  text-align: center;
}

.footer-privacy text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  text-decoration: underline;
}

/* 隐私政策弹窗 */
.privacy-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.privacy-modal {
  width: 100%;
  max-width: 640rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.privacy-modal-header {
  padding: 40rpx 30rpx 20rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.privacy-modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.privacy-modal-body {
  padding: 30rpx;
}

.privacy-notice {
  margin-bottom: 30rpx;
}

.notice-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.notice-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.privacy-list {
  margin-bottom: 30rpx;
}

.privacy-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.privacy-item:last-child {
  margin-bottom: 0;
}

.privacy-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.privacy-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.privacy-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.privacy-summary {
  background: #fff8e1;
  padding: 20rpx;
  border-radius: 12rpx;
  border-left: 6rpx solid #ffc107;
}

.privacy-summary text {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
}

.privacy-summary text:first-child {
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.privacy-modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
}

.btn-reject {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
}

.btn-reject::after {
  border: none;
}

.btn-agree {
  flex: 2;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 12rpx;
  border: none;
}

.btn-agree::after {
  border: none;
}