/* pages/login/login.wxss */
.container {
  min-height: 100vh;
  padding: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.logo-area {
  text-align: center;
  padding: 60rpx 0;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 10rpx;
}

.top3-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.top3-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.top3-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.top3-item .rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffd700, #ffaa00);
  color: #fff;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.top3-item .info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.top3-item .name {
  font-size: 28rpx;
  color: #333;
}

.top3-item .hit-rate {
  font-size: 24rpx;
  color: #667eea;
  font-weight: bold;
}

.login-area {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 40rpx;
}

.username-input {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 30rpx;
  font-size: 32rpx;
  margin-bottom: 30rpx;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}

.switch-text {
  text-align: center;
  font-size: 26rpx;
  color: #667eea;
  margin-top: 30rpx;
}

.user-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.user-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.user-item .avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.user-item .username {
  font-size: 28rpx;
  color: #333;
}

.wechat-login {
  margin-top: 40rpx;
}

.divider {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.divider::before,
.divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #ddd;
}

.divider text {
  padding: 0 20rpx;
  font-size: 24rpx;
  color: #999;
}

.btn-wechat {
  width: 100%;
  height: 88rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.btn-wechat::after {
  border: none;
}

.btn-wechat .icon {
  font-size: 36rpx;
}