/* pages/login/login.wxss */
.container {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 100rpx;
  overflow: hidden; /* 禁止整个页面滚动 */
  display: flex;
  flex-direction: column;
}

.logo-area {
  text-align: center;
  padding: 40rpx 0 24rpx;
}

.logo {
  font-size: 100rpx;
  margin-bottom: 12rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

/* 排行榜 - 居中显示 */
.top3-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  text-align: center;
}

.top3-list {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  width: 100%;
}

.top3-item {
  display: flex;
  align-items: center;
  gap: 48rpx; /* 原来 16rpx，扩大 3 倍 */
  width: 80%;
  justify-content: center;
}

.top3-item .rank {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffd700, #ffaa00);
  color: #fff;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0; /* 防止排名被压缩 */
}

.top3-item .info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  max-width: 400rpx; /* 增加宽度容纳更大间距 */
}

.top3-item .name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  text-align: center;
}

.top3-item .hit-rate {
  font-size: 24rpx;
  color: #667eea;
  font-weight: bold;
  flex-shrink: 0; /* 防止命中率被压缩 */
  min-width: 120rpx; /* 保证命中率显示完整 */
  text-align: right;
}

.login-area {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 28rpx;
}

.username-input {
  width: 100%;
  height: 88rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 0 28rpx;
  font-size: 32rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}

.switch-text {
  text-align: center;
  font-size: 28rpx;
  color: #667eea;
  margin-top: 24rpx;
  padding: 16rpx 24rpx;
  border-radius: 10rpx;
}

/* 创建新账号 - 黄色填充 */
.switch-text-yellow {
  background: linear-gradient(135deg, #fff8e1, #ffe082);
  color: #f57c00;
  font-weight: 500;
}

/* 账号选择区域 - 可滑动 */
.user-scroll {
  height: 400rpx; /* 固定高度 */
  overflow-y: scroll; /* 允许垂直滚动 */
  -webkit-overflow-scrolling: touch; /* iOS 平滑滚动 */
  margin-bottom: 16rpx;
}

.user-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 4rpx;
}

/* 用户框 - 缩小 + 淡蓝色边框 */
.user-item {
  width: calc((100% - 24rpx) / 3);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 8rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 3rpx solid #90caf9;
  box-shadow: 0 2rpx 8rpx rgba(144, 202, 249, 0.3);
}

.user-item:active {
  background: #e3f2fd;
  border-color: #42a5f5;
}

.user-item .avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid #e3f2fd;
}

.user-item .username {
  font-size: 26rpx;
  color: #333;
  text-align: center;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.wechat-login {
  margin-top: 32rpx;
}

.divider {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.divider::before,
.divider::after {
  content: '';
  flex: 1;
  height: 2rpx;
  background: #ddd;
}

.divider text {
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #999;
}

.btn-wechat {
  width: 100%;
  height: 88rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.btn-wechat::after {
  border: none;
}

.btn-wechat .icon {
  font-size: 36rpx;
}

/* 底部隐私政策入口 */
.footer-privacy {
  position: fixed;
  bottom: 30rpx;
  left: 0;
  right: 0;
  text-align: center;
}

.footer-privacy text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  text-decoration: underline;
}

/* 隐私政策弹窗 */
.privacy-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.privacy-modal {
  width: 100%;
  max-width: 640rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.privacy-modal-header {
  padding: 40rpx 30rpx 24rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.privacy-modal-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
}

.privacy-modal-body {
  padding: 32rpx;
}

.privacy-notice {
  margin-bottom: 32rpx;
}

.notice-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.notice-text {
  display: block;
  font-size: 30rpx;
  color: #666;
  line-height: 1.6;
}

.privacy-list {
  margin-bottom: 32rpx;
}

.privacy-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.privacy-item:last-child {
  margin-bottom: 0;
}

.privacy-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.privacy-name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.privacy-arrow {
  font-size: 30rpx;
  color: #ccc;
}

.privacy-summary {
  background: #fff8e1;
  padding: 24rpx;
  border-radius: 12rpx;
  border-left: 6rpx solid #ffc107;
}

.privacy-summary text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.privacy-summary text:first-child {
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.privacy-modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
}

.btn-reject {
  flex: 1;
  height: 88rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
}

.btn-reject::after {
  border: none;
}

.btn-agree {
  flex: 2;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 12rpx;
  border: none;
}

.btn-agree::after {
  border: none;
}