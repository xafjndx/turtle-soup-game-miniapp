/* pages/profile/profile.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

.user-section {
  display: flex;
  align-items: center;
  gap: 30rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 40rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar image {
  width: 100%;
  height: 100%;
}

.info {
  flex: 1;
}

.name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 10rpx;
}

.rank {
  display: inline-block;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #fff;
}

.stats-section {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
}

.stat-card.highlight {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
}

.stat-card .value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.stat-card.highlight .value {
  color: #667eea;
}

.stat-card .label {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}

/* 管理后台入口 */
.admin-section {
  margin-bottom: 30rpx;
}

.admin-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #ff9800, #ff5722);
  padding: 30rpx;
  border-radius: 16rpx;
}

.admin-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.admin-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.admin-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.admin-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.admin-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 功能菜单 */
.menu-section {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.menu-item.danger .menu-text {
  color: #ff4d4f;
}

.detail-section, .history-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.detail-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-item .label {
  font-size: 28rpx;
  color: #666;
}

.detail-item .value {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  background: #f8f9ff;
  border-radius: 12rpx;
}

.history-item .result {
  width: 48rpx;
  height: 48rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
}

.history-item .result.win {
  background: #4caf50;
}

.history-item .result.lose {
  background: #f44336;
}

.history-item .info {
  flex: 1;
}

.history-item .surface {
  font-size: 26rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.history-item .meta {
  font-size: 22rpx;
  color: #999;
  display: flex;
  gap: 8rpx;
}

.logout-section {
  margin-top: 30rpx;
}

.btn-logout {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #f44336;
  font-size: 30rpx;
  border-radius: 16rpx;
  border: 2rpx solid #f44336;
}

.btn-logout::after {
  border: none;
}

/* 注销账号弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.modal-content {
  width: 100%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-header {
  padding: 30rpx;
  background: #fff5f5;
  text-align: center;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.modal-body {
  padding: 30rpx;
}

.modal-text {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.modal-list {
  background: #f8f8f8;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.modal-item {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 2;
}

.modal-warning {
  display: block;
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: bold;
  text-align: center;
  padding: 20rpx 0;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #eee;
}

.modal-btn {
  flex: 1;
  height: 100rpx;
  font-size: 30rpx;
  border-radius: 0;
  border: none;
  background: #fff;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  color: #666;
  border-right: 1rpx solid #eee;
}

.modal-btn.confirm {
  color: #ff4d4f;
  font-weight: bold;
}