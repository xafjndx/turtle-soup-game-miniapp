<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息 - 退出按钮移到右上角 -->
  <view class="user-section">
    <view class="avatar">
      <image src="{{userInfo.avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
    </view>
    <view class="info">
      <text class="name">{{userInfo.nickname || userInfo.username}}</text>
    </view>
    <view class="right-section">
      <view class="rank" bindtap="onViewLeaderboard">
        <text>排名 #{{userInfo.rank || '--'}}</text>
      </view>
      <button class="btn-logout-top" bindtap="onLogout">退出登录</button>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="stats-section">
    <view class="stat-card">
      <view class="value">{{userInfo.totalGames || 0}}</view>
      <view class="label">游戏局数</view>
    </view>
    <view class="stat-card">
      <view class="value">{{userInfo.winCount || 0}}</view>
      <view class="label">猜中次数</view>
    </view>
    <view class="stat-card highlight">
      <view class="value">{{userInfo.hitRate || 0}}%</view>
      <view class="label">命中率</view>
    </view>
    <view class="stat-card">
      <view class="value">{{userInfo.avgPlayTime || 0}}</view>
      <view class="label">平均用时(分)</view>
    </view>
  </view>

  <!-- 管理后台入口（仅管理员可见） -->
  <view class="admin-section" wx:if="{{isAdmin}}" bindtap="onEnterAdmin">
    <view class="admin-card">
      <text class="admin-icon">⚙️</text>
      <view class="admin-info">
        <text class="admin-title">管理后台</text>
        <text class="admin-desc">审核题目、查看数据</text>
      </view>
      <text class="admin-arrow">></text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="onViewPrivacy">
      <text class="menu-icon">🔒</text>
      <text class="menu-text">隐私政策</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onExportData">
      <text class="menu-icon">📤</text>
      <text class="menu-text">导出我的数据</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item danger" bindtap="onShowDeleteModal">
      <text class="menu-icon">🗑️</text>
      <text class="menu-text">注销账号</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <!-- 详细统计 -->
  <view class="detail-section">
    <view class="section-title">详细数据</view>
    <view class="detail-list">
      <view class="detail-item">
        <text class="label">总游戏时间</text>
        <text class="value">{{userInfo.totalPlayTime || 0}} 分钟</text>
      </view>
      <view class="detail-item">
        <text class="label">单局最长时间</text>
        <text class="value">{{userInfo.maxPlayTime || 0}} 分钟</text>
      </view>
      <view class="detail-item">
        <text class="label">平均提示使用</text>
        <text class="value">{{userInfo.avgHintsPerGame || 0}} 次</text>
      </view>
      <view class="detail-item">
        <text class="label">总提示使用</text>
        <text class="value">{{userInfo.totalHintsUsed || 0}} 次</text>
      </view>
    </view>
  </view>

  <!-- 最近游戏 -->
  <view class="history-section" wx:if="{{history.length > 0}}">
    <view class="section-title">最近游戏</view>
    <view class="history-list">
      <view class="history-item" wx:for="{{history}}" wx:key="id">
        <view class="result {{item.result === 'WIN' ? 'win' : 'lose'}}">
          {{item.result === 'WIN' ? '胜' : '负'}}
        </view>
        <view class="info">
          <view class="surface">{{item.question.surface}}</view>
          <view class="meta">
            <text>{{item.playTime}}分钟</text>
            <text>·</text>
            <text>{{item.hintUsed}}提示</text>
            <text>·</text>
            <text>{{item.hitRate}}%命中</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 注销账号确认弹窗 -->
<view class="modal-mask" wx:if="{{showDeleteModal}}" catchtouchmove="true">
  <view class="modal-content">
    <view class="modal-header">
      <text class="modal-title">⚠️ 注销账号</text>
    </view>
    <view class="modal-body">
      <text class="modal-text">您正在申请注销账号，注销后：</text>
      <view class="modal-list">
        <text class="modal-item">• 您的所有个人信息将被删除</text>
        <text class="modal-item">• 游戏记录将无法恢复</text>
        <text class="modal-item">• 排行榜数据将被清除</text>
        <text class="modal-item">• 此操作不可撤销</text>
      </view>
      <text class="modal-warning">确定要注销账号吗？</text>
    </view>
    <view class="modal-footer">
      <button class="modal-btn cancel" bindtap="onHideDeleteModal">取消</button>
      <button class="modal-btn confirm" bindtap="onConfirmDelete">确认注销</button>
    </view>
  </view>
</view>