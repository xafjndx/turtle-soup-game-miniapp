/* pages/submit-question/submit-question.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 200rpx;
}

/* 投稿排行榜 */
.leaderboard-section {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.leaderboard-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.leaderboard-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.leaderboard-item .rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  background: #e0e0e0;
  color: #666;
}

.leaderboard-item .rank-1 {
  background: linear-gradient(135deg, #ffd700, #ffaa00);
  color: #fff;
}

.leaderboard-item .rank-2 {
  background: linear-gradient(135deg, #c0c0c0, #a0a0a0);
  color: #fff;
}

.leaderboard-item .rank-3 {
  background: linear-gradient(135deg, #cd7f32, #b8860b);
  color: #fff;
}

.leaderboard-item .avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.leaderboard-item .nickname {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.leaderboard-item .count {
  font-size: 24rpx;
  color: #667eea;
  font-weight: bold;
}

/* 投稿须知 */
.notice-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #e8f4fd;
  border-bottom: 1rpx solid #d0e8f7;
}

.notice-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.notice-text {
  flex: 1;
  font-size: 28rpx;
  color: #1890ff;
}

.notice-arrow {
  font-size: 28rpx;
  color: #1890ff;
}

/* 表单区域 */
.form-section {
  padding: 20rpx;
}

.form-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.label-required {
  color: #ff4d4f;
  margin-left: 4rpx;
}

.label-optional {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.label-hint {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 分类选择 */
.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  width: calc(50% - 8rpx);
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.category-item.active {
  background: #f0e8ff;
  border-color: #667eea;
}

.category-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.category-item.active .category-name {
  color: #667eea;
}

.category-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
}

/* 提示列表 */
.hints-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hint-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hint-label {
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
}

.hint-input {
  flex: 1;
  height: 70rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
}

/* 提交区域 */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-tip {
  text-align: center;
  margin-top: 16rpx;
}

.submit-tip text {
  font-size: 22rpx;
  color: #999;
}