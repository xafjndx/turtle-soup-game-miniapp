/* pages/game/game.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.surface-section {
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 40rpx;
  color: #fff;
}

.surface-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.surface-header .label {
  font-size: 32rpx;
  font-weight: bold;
}

.hint-badge {
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.surface-content {
  font-size: 30rpx;
  line-height: 1.8;
  background: rgba(255, 255, 255, 0.1);
  padding: 30rpx;
  border-radius: 16rpx;
}

.hint-info {
  margin-top: 20rpx;
  font-size: 26rpx;
  opacity: 0.9;
}

.rounds-section {
  flex: 1;
  padding: 30rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.rounds-list {
  max-height: 500rpx;
}

.round-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.round-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.round-num {
  font-size: 24rpx;
  font-weight: bold;
  color: #667eea;
}

.round-action {
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.player-input, .ai-response {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.ai-response {
  margin-bottom: 0;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: bold;
  white-space: nowrap;
}

.player-input .tag {
  background: #e3f2fd;
  color: #1976d2;
}

.ai-response .tag {
  background: #f5f5f5;
  color: #666;
}

.ai-response .tag.YES {
  background: #e8f5e9;
  color: #4caf50;
}

.ai-response .tag.NO {
  background: #ffebee;
  color: #f44336;
}

.ai-response .tag.IRRELEVANT {
  background: #fff3e0;
  color: #ff9800;
}

.text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

.input-section {
  background: #fff;
  padding: 30rpx;
  border-top: 1rpx solid #eee;
}

.input-mode {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.mode-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.mode-btn.active {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  color: #667eea;
}

.mode-btn .icon {
  font-size: 32rpx;
}

.text-input {
  margin-bottom: 20rpx;
}

.input-area {
  width: 100%;
  height: 160rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.voice-input {
  margin-bottom: 20rpx;
}

.record-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 160rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.record-btn.recording {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

.record-btn .icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.record-btn .tip {
  font-size: 26rpx;
  color: inherit;
}

.action-btns {
  display: flex;
  gap: 16rpx;
}

.action-btns button {
  flex: 1;
  height: 80rpx;
  font-size: 26rpx;
  border-radius: 12rpx;
  border: none;
}

.action-btns button::after {
  border: none;
}

.btn-hint {
  background: #fff3e0;
  color: #ff9800;
}

.btn-ask {
  background: #e3f2fd;
  color: #1976d2;
}

.btn-guess {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

.btn-end {
  background: #ffebee;
  color: #f44336;
}

/* 弹窗样式 */
.hint-modal, .end-modal, .result-modal, .save-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-desc {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-btns {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.modal-btns button {
  height: 80rpx;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
}

.modal-btns button::after {
  border: none;
}

.btn-view {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

.btn-mystery {
  background: #f5f5f5;
  color: #666;
}

.btn-cancel {
  background: transparent;
  color: #999;
}

.result-icon {
  font-size: 80rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  color: #333;
  margin-bottom: 16rpx;
}

.result-hit-rate {
  font-size: 28rpx;
  color: #667eea;
  text-align: center;
  margin-bottom: 20rpx;
}

.result-answer {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.result-answer .label {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.result-answer .text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.btn-again {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

.btn-home {
  background: #f5f5f5;
  color: #666;
}

.btn-save {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

.btn-skip {
  background: #f5f5f5;
  color: #666;
}

.hint-content {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
}

.hint-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.hint-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

.btn-close {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
}

.btn-close::after {
  border: none;
}

/* AI题目保存区域 */
.save-question-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.save-question-section button {
  flex: 1;
  height: 70rpx;
  font-size: 26rpx;
  border-radius: 12rpx;
  border: none;
}

.save-question-section button::after {
  border: none;
}

.btn-save-question {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

.btn-skip-save {
  background: #f5f5f5;
  color: #666;
}

.end-btns {
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
  margin-top: 20rpx;
}

.tag.ask {
  background: #e3f2fd;
  color: #1976d2;
}

.ai-response .tag.CORRECT {
  background: #e8f5e9;
  color: #4caf50;
}

/* 结束选择弹窗 */
.end-choice-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 110;
  display: flex;
  align-items: center;
  justify-content: center;
}

.end-choice-modal .modal-content {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
}