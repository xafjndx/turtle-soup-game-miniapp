<!--pages/game/game.wxml-->
<view class="container">
  <!-- 自定义导航栏（无返回按钮） -->
  <view class="custom-navbar">
    <view class="navbar-left-placeholder"></view>
    <view class="navbar-title">游戏中</view>
    <view class="navbar-right-placeholder"></view>
  </view>

  <!-- 汤面展示 -->
  <view class="surface-section">
    <view class="surface-header">
      <text class="label">【汤面】</text>
      <view class="hint-badge" wx:if="{{hasPlayed}}">
        <text>已玩过</text>
      </view>
    </view>
    <view class="surface-content">
      {{question.surface}}
    </view>
  </view>

  <!-- 输入区域 -->
  <view class="input-section">
    <!-- 输入方式选择 -->
    <view class="input-mode">
      <view class="mode-btn {{inputMode === 'TEXT' ? 'active' : ''}}" data-mode="TEXT" bindtap="onSelectInputMode">
        <text class="icon">⌨️</text>
        <text>文字</text>
      </view>
      <view class="mode-btn {{inputMode === 'VOICE' ? 'active' : ''}}" data-mode="VOICE" bindtap="onSelectInputMode">
        <text class="icon">🎤</text>
        <text>语音</text>
      </view>
    </view>

    <!-- 文字输入 -->
    <view class="text-input" wx:if="{{inputMode === 'TEXT'}}">
      <textarea 
        class="input-area"
        placeholder="输入你的问题或猜测..."
        maxlength="200"
        value="{{playerInput}}"
        bindinput="onInputChange"
      />
    </view>

    <!-- 语音输入 -->
    <view class="voice-input" wx:else>
      <view 
        class="record-btn {{isRecording ? 'recording' : ''}}"
        bindtouchstart="startRecording"
        bindtouchend="stopRecording"
      >
        <text class="icon">🎤</text>
        <text class="tip">{{isRecording ? '松开结束' : '按住说话'}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-btns">
      <button class="btn-hint" bindtap="onUseHint" disabled="{{hintRemaining <= 0}}">
        <text class="btn-text">提示</text>
        <text class="btn-num">({{hintRemaining}})</text>
      </button>
      <button class="btn-ask" bindtap="onSubmitAsk">提问</button>
      <button class="btn-guess" bindtap="onSubmitGuess">猜答案</button>
      <button class="btn-end" bindtap="onEndGame">结束</button>
    </view>
  </view>

  <!-- 回合历史（移到最下面） -->
  <view class="rounds-section" wx:if="{{rounds.length > 0}}">
    <view class="section-title">对话记录（共{{rounds.length}}轮）</view>
    <scroll-view scroll-y class="rounds-list" scroll-into-view="round-{{rounds.length}}">
      <view class="round-item" wx:for="{{rounds}}" wx:key="id" id="round-{{index + 1}}">
        <view class="round-header">
          <text class="round-num">第{{index + 1}}轮</text>
          <text class="round-action">{{item.action === 'GUESS' ? '猜测' : '提问'}}</text>
        </view>
        <view class="player-input">
          <text class="tag ask">问</text>
          <text class="text">{{item.playerInput}}</text>
        </view>
        <view class="ai-response">
          <text class="tag {{item.answerType}}">{{item.answerType === 'YES' ? '是' : item.answerType === 'NO' ? '否' : item.answerType === 'IRRELEVANT' ? '无关' : item.answerType === 'CORRECT' ? '猜中' : '部分正确'}}</text>
          <text class="text">{{item.aiResponse}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 提示弹窗 -->
  <view class="hint-modal" wx:if="{{currentHint}}" bindtap="onCloseHint">
    <view class="hint-content" catchtap="stopPropagation">
      <view class="hint-title">💡 提示</view>
      <view class="hint-text">{{currentHint}}</view>
      <button class="btn-close" bindtap="onCloseHint">知道了</button>
    </view>
  </view>

  <!-- 结束选项弹窗 -->
  <view class="end-modal" wx:if="{{showEndModal}}">
    <view class="modal-mask" bindtap="hideEndModal"></view>
    <view class="modal-content">
      <view class="modal-title">确定要结束游戏吗？</view>
      <view class="modal-btns">
        <button class="btn-view" bindtap="onViewAnswer">查看汤底</button>
        <button class="btn-mystery" bindtap="onKeepMystery">保留神秘感</button>
        <button class="btn-cancel" bindtap="hideEndModal">继续游戏</button>
      </view>
    </view>
  </view>

  <!-- 猜中结果弹窗 -->
  <view class="result-modal" wx:if="{{showResultModal}}">
    <view class="modal-mask"></view>
    <view class="modal-content result-content">
      <!-- 根据是否查看汤底显示不同图标 -->
      <view class="result-icon">{{revealedAnswer ? '💪' : '🎉'}}</view>
      <view class="result-title">{{revealedAnswer ? '继续加油！' : '恭喜猜中！'}}</view>
      <view class="result-hit-rate" wx:if="{{gameResult.hitRate}}">
        最终重合率：{{gameResult.hitRate}}%
      </view>
      
      <!-- 汤底展示（只有点击查看汤底才显示） -->
      <view class="result-answer" wx:if="{{revealedAnswer && gameResult.answer}}">
        <view class="label">【汤底】</view>
        <view class="text">{{gameResult.answer}}</view>
      </view>
      
      <!-- AI题目入库按钮（只有AI生成的题目且已显示汤底且未保存才显示） -->
      <view class="save-question-section" wx:if="{{session.questionSource === 'AI_GENERATED' && revealedAnswer && !savedToBank}}">
        <button class="btn-save-question" bindtap="onSaveQuestion">加入题库</button>
        <button class="btn-skip-save" bindtap="onSkipSave">跳过</button>
      </view>
      
      <!-- 操作按钮 -->
      <view class="modal-btns result-btns">
        <!-- 未查看汤底时 -->
        <button class="btn-view-answer" bindtap="onViewAnswerFromResult" wx:if="{{!revealedAnswer}}">查看汤底</button>
        <button class="btn-continue" bindtap="onContinueGame" wx:if="{{!revealedAnswer}}">继续游戏</button>
        <!-- 已查看汤底且（非AI题目 或 已处理题库选项）时显示 -->
        <block wx:if="{{revealedAnswer && (session.questionSource !== 'AI_GENERATED' || savedToBank)}}">
          <button class="btn-again" bindtap="onPlayAgain">再来一局</button>
          <button class="btn-home" bindtap="onBackHome">返回主界面</button>
        </block>
      </view>
    </view>
  </view>

  <!-- 结束选择弹窗（再来一局/返回首页） -->
  <view class="end-choice-modal" wx:if="{{showEndChoice}}">
    <view class="modal-mask"></view>
    <view class="modal-content">
      <view class="result-icon">💪</view>
      <view class="result-title">继续加油！</view>
      <view class="modal-btns">
        <button class="btn-again" bindtap="onPlayAgain">再来一局</button>
        <button class="btn-home" bindtap="onBackHome">返回首页</button>
      </view>
    </view>
  </view>
</view>