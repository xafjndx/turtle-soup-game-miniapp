/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  padding: 30rpx;
  background: linear-gradient(180deg, #f8f9ff 0%, #fff 100%);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0 30rpx;
}

.welcome {
  display: flex;
  flex-direction: column;
}

.greeting {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.stats {
  display: flex;
  gap: 30rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 20rpx 30rpx;
  border-radius: 16rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-item .value {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.stat-item .label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.category-section {
  margin-top: 30rpx;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.category-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  border: 2rpx solid #eee;
  transition: all 0.3s;
}

.category-item.active {
  border-color: #667eea;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
}

.category-item .icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 10rpx;
}

.category-item .name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.category-item .desc {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}

.source-section {
  margin-top: 40rpx;
}

.source-options {
  display: flex;
  gap: 20rpx;
}

.source-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #eee;
  transition: all 0.3s;
}

.source-item.active {
  border-color: #667eea;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
}

.source-item .icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.source-item .label {
  font-size: 26rpx;
  color: #333;
}

.action-section {
  margin-top: 50rpx;
}

.btn-start {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 16rpx;
  border: none;
}

.btn-start::after {
  border: none;
}

/* 投稿入口 */
.submit-section {
  margin-top: 30rpx;
}

.submit-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #fff5e6, #ffe8cc);
  padding: 30rpx;
  border-radius: 16rpx;
  border: 2rpx solid #ffd699;
}

.submit-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.submit-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.submit-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #ff8c00;
}

.submit-desc {
  font-size: 24rpx;
  color: #cc7000;
  margin-top: 4rpx;
}

.submit-arrow {
  font-size: 32rpx;
  color: #ff8c00;
}

.leaderboard-section {
  margin-top: 50rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.more {
  font-size: 24rpx;
  color: #667eea;
}

.top3-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.top3-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  background: #f8f9ff;
  border-radius: 12rpx;
}

.top3-item .rank {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #ddd;
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.top3-item .rank-1 {
  background: linear-gradient(135deg, #ffd700, #ffaa00);
}

.top3-item .rank-2 {
  background: linear-gradient(135deg, #c0c0c0, #a0a0a0);
}

.top3-item .rank-3 {
  background: linear-gradient(135deg, #cd7f32, #b87333);
}

.top3-item .info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.top3-item .name {
  font-size: 26rpx;
  color: #333;
}

.top3-item .hit-rate {
  font-size: 22rpx;
  color: #667eea;
  margin-top: 4rpx;
}

.top3-item .games {
  font-size: 24rpx;
  color: #999;
}