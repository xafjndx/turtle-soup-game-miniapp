.privacy-container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.privacy-header {
  background-color: #fff;
  padding: 40rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.privacy-header .title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.privacy-header .update-time,
.privacy-header .effective-time {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.privacy-content {
  background-color: #fff;
  padding: 40rpx;
  border-radius: 16rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #07c160;
}

.subsection {
  margin-top: 20rpx;
  padding-left: 20rpx;
}

.subsection-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 10rpx;
}

.section-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.privacy-footer {
  text-align: center;
  padding: 40rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
}